# ============================================
# NormaCheck - Variables d'environnement
# Copier vers .env et adapter
# ============================================

# Environnement (production | development | staging)
NORMACHECK_ENV=production

# Repertoire des donnees persistantes
NORMACHECK_DATA_DIR=/data/normacheck

# Nombre de workers Gunicorn (defaut: 2 * CPU + 1)
NORMACHECK_WORKERS=4

# Limites d'upload (sans contrainte Vercel)
NORMACHECK_MAX_UPLOAD_MB=2000
NORMACHECK_MAX_FILES=50

# Cle secrete JWT (OBLIGATOIRE en production - generez une cle aleatoire)
# python3 -c "import secrets; print(secrets.token_hex(32))"
NORMACHECK_SECRET_KEY=CHANGEZ-MOI-cle-secrete-aleatoire

# Duree de validite du token JWT en heures (defaut: 24)
NORMACHECK_TOKEN_EXPIRY=24

# Cle de chiffrement des fichiers au repos (RGPD art. 32)
# python3 -c "import secrets; print(secrets.token_hex(32))"
NORMACHECK_ENCRYPTION_KEY=CHANGEZ-MOI-cle-chiffrement-fichiers

# Retention des fichiers uploades en jours (RGPD art. 5.1.e - defaut: 90)
NORMACHECK_RETENTION_UPLOADS_DAYS=90

# Retention du journal d'audit en jours (defaut: 1825 = 5 ans, art. L102 B LPF)
NORMACHECK_RETENTION_AUDIT_DAYS=1825

# HTTPS actif (1 = oui, 0 = non) - pour cookies securises
NORMACHECK_HTTPS=1

# Compte admin par defaut (cree automatiquement si aucun admin n'existe)
NORMACHECK_ADMIN_EMAIL=admin@normacheck.fr
NORMACHECK_ADMIN_PASSWORD=Admin2026!Norma

# Port (defaut: 8000)
PORT=8000

# Domaine (pour SSL et nginx)
NORMACHECK_DOMAIN=normacheck.votredomaine.fr
NORMACHECK_EMAIL=admin@votredomaine.fr

# Supabase (optionnel - decommenter si utilise)
# SUPABASE_URL=https://xxx.supabase.co
# SUPABASE_KEY=eyJ...

# Logging
NORMACHECK_LOG_LEVEL=info
